<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.TravelGo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">#3B82F6</item>
        <item name="colorPrimaryVariant">#2563EB</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Secondary -->
        <item name="colorSecondary">#10B981</item>
        <item name="colorSecondaryVariant">#059669</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Surface -->
        <item name="colorSurface">#1F2937</item>
        <item name="colorOnSurface">#F9FAFB</item>

        <!-- Background -->
        <item name="android:colorBackground">#111827</item>
        <item name="colorOnBackground">#F9FAFB</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">?attr/colorPrimary</item>

        <!-- TextInputLayout default style -->
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
    </style>
</resources>