<resources>

    <!-- Tab -->
    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ShapeableImageView: lingkaran penuh -->
    <style name="CircleImageView" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ShapeableImageView: sudut rounded 8dp (dipakai item_review.xml) -->
    <style name="RoundedCorner8" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <!-- ShapeableImageView: sudut rounded 12dp -->
    <style name="RoundedCorner12" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- ShapeableImageView: sudut rounded 16dp -->
    <style name="RoundedCorner16" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

</resources>